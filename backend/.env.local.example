# ---------------------------------------------------------------------------
# Recco backend (Person B) environment variables.
#
# Copy this file to `.env.local` and fill in the values you want to enable.
# Every variable is OPTIONAL: with none set, the backend runs in a fully
# offline/mock mode that still returns the exact JSON shapes from
# docs/API_CONTRACTS.md. Fill these in to switch to the "real" path.
#
# For a deployed Convex backend, set the same variables with:
#   npx convex env set OPENAI_API_KEY sk-...
# (Convex actions read process.env from the deployment, not this file.)
# ---------------------------------------------------------------------------

# Person A's CV / face-embedding service. When reachable + ready, both
# vision:matchFace and the enrollment script (`npm run enroll`) call
# POST {CV_SERVICE_URL}/embed for a real 512-d embedding. When it is unreachable
# or not ready, they fall back to deterministic mock embeddings.
# See docs/FACE_ENROLLMENT.md for the full enrollment workflow.
CV_SERVICE_URL=http://127.0.0.1:8000

# OpenAI API key. When set, voice:interpretCommand and drafts:createOpener use
# the model below. When empty, both fall back to deterministic local logic that
# returns the SAME JSON shapes.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Deepgram project API key. When set, voice:getDeepgramToken mints a short-lived
# streaming token via Deepgram's grant endpoint. When empty, it returns a
# clearly-marked stub token so the iOS app can fall back to typed/chip commands.
DEEPGRAM_API_KEY=

# Face match thresholds (cosine similarity on L2-normalized 512-d embeddings).
FACE_STRONG_MATCH_SCORE=0.38
FACE_TENTATIVE_MATCH_SCORE=0.30

# ---------------------------------------------------------------------------
# Identity resolution ("find info on him") — POST /api/identity/resolve.
#
# This lane reads a badge with OpenAI Vision, finds candidate profiles with
# Fiber AI, and face-verifies them against the live face via the CV service.
# All three keys live ONLY here (server-side); the iOS app never holds them.
# With keys empty, the action degrades honestly (needs_clarification / not_found)
# and the iOS MockBackend returns a demo identity for `mockAll`.
# ---------------------------------------------------------------------------

# Fiber AI person-lookup API key. When set, identity:resolveTarget calls the
# Fiber "Kitchen Sink" person endpoint to turn an extracted name into candidate
# profiles (LinkedIn, role, company, photo, email). When empty, the action
# returns not_found instead of inventing data.
FIBER_API_KEY=
# Fiber API base URL (no trailing slash). Defaults to https://api.fiber.ai.
FIBER_API_BASE_URL=https://api.fiber.ai

# OpenAI vision model used to read the badge/name tag (OCR + extraction). Reuses
# OPENAI_API_KEY above. Defaults to gpt-4o. Must be a vision-capable model.
OPENAI_VISION_MODEL=gpt-4o

# Identity thresholds.
#   IDENTITY_MIN_OCR_CONFIDENCE   - below this, the read is treated as unreliable
#                                   and the result is needs_clarification (0..1).
#   IDENTITY_FACE_VERIFY_THRESHOLD - cosine floor for declaring a candidate's
#                                   profile photo a match for the live face. A
#                                   candidate is only ever "verified" at/above
#                                   this (0..1).
IDENTITY_MIN_OCR_CONFIDENCE=0.45
IDENTITY_FACE_VERIFY_THRESHOLD=0.32

# ---------------------------------------------------------------------------
# iOS-side configuration (for reference — set these in the iOS run scheme /
# environment, NOT in the Convex deployment). The app reads RECCO_API_BASE_URL
# first, then CONVEX_URL, to find the HTTP bridge. Leave empty to run fully
# offline on the bundled roster + mocks.
# ---------------------------------------------------------------------------
# RECCO_API_BASE_URL=https://<your-deployment>.convex.site
# CONVEX_URL=https://<your-deployment>.convex.site
